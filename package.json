{
  "name": "rebalancer",
  "version": "0.1.0",
  "private": true,
  "description": "Portfolio rebalancing calculator: computes buy-only trades to bring a multi-account portfolio toward target asset allocations.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:watch": "pnpm --filter @rebalancer/solver run test:watch",
    "build": "pnpm -r run build",
    "solve": "tsx apps/cli/src/index.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
